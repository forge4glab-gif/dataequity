<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DataEquity - Ativação</title>
    <link rel="manifest" href="/manifest.json">
    <style>
        body { font-family: sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; margin: 0; background: #f4f4f9; }
        .btn-nexo { padding: 20px 40px; font-size: 1.2rem; color: #fff; background: #000; border: none; border-radius: 50px; cursor: pointer; box-shadow: 0 4px 15px rgba(0,0,0,0.2); }
        .status { margin-top: 20px; color: #666; font-size: 0.9rem; }
    </style>
</head>
<body>
    <button class="btn-nexo" onclick="ativarSoberania()">ATIVAR MONETIZAÇÃO</button>
    <div id="status" class="status">Nexo: Aguardando Ativação</div>

    <script>
        async function ativarSoberania() {
            const statusDiv = document.getElementById('status');
            
            // 1. Solicita Notificações (+R$ 0,08)
            const permission = await Notification.requestPermission();
            
            if (permission === 'granted') {
                // 2. Registra o Service Worker para Nexo Permanente
                if ('serviceWorker' in navigator) {
                    const reg = await navigator.serviceWorker.register('/sw.js');
                    statusDiv.innerText = "Nexo: Ativo e Permanente";
                    statusDiv.style.color = "green";
                    
                    // 3. Simula o primeiro rito de salvamento
                    reg.active.postMessage({type: 'MONETIZACAO_CONFIRMADA'});
                }
            } else {
                statusDiv.innerText = "Erro: Permissão Necessária";
                statusDiv.style.color = "red";
            }
        }
    </script>
</body>
</html>
